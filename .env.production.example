# ══════════════════════════════════════════════════════════════
#  EdgeStone Ticketing System — Production Environment Variables
#  INSTRUCTIONS:
#    cp .env.production.example .env.production
#    nano .env.production          ← fill in all values below
#  NEVER commit .env.production to git.
# ══════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (Render PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_use_a_long_random_string_here
JWT_EXPIRES_IN=1d

# ── CORS: Extra frontend URL (*.vercel.app already allowed) ───
FRONTEND_URL=https://edgestonefrontend.vercel.app

# ── Email Provider ────────────────────────────────────────────
# zepto  = ZeptoMail HTTP API  (RECOMMENDED — works on Hostinger)
# smtp   = Zoho SMTP direct    (also works on Hostinger VPS)
EMAIL_PROVIDER=zepto

# ── ZeptoMail (primary outgoing) ─────────────────────────────
ZEPTO_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTO_MAIL_TOKEN=Zoho-enczapikey YOUR_TOKEN_HERE
ZEPTO_FROM_EMAIL=noreply@edgestone.in

# ── Zoho IMAP (incoming mail — ticket creation) ───────────────
MAIL_USER=marketing@edgestone.in
MAIL_PASSWORD=YOUR_ZOHO_APP_PASSWORD
IMAP_HOST=imappro.zoho.in
IMAP_PORT=993
IMAP_SECURE=true

# ── Zoho SMTP (outgoing fallback — works on Hostinger VPS) ───
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_SECURE=true

# ── Resend (optional fallback) ────────────────────────────────
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=marketing@edgestone.in
RESEND_REPLY_TO=marketing@edgestone.in
